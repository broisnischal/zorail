# Zorail configuration — copy to .env and edit, or let `zorail setup` write it.
# The server auto-loads .env from its working directory (override with
# ZORAIL_ENV_FILE). Real environment variables always win over this file.
# `zorail setup` manages the starred (*) values for you.

# ── Identity ────────────────────────────────────────────────────────────────
# The mail domain this server handles. Inboxes are <anything>@ZORAIL_DOMAIN.
ZORAIL_DOMAIN=localhost
# Restrict which recipient domains are accepted (comma-separated). Empty = accept
# every domain (open catch-all) — fine locally, set it in production.
ZORAIL_ALLOWED_DOMAINS=

# ── Listeners ─────────────────────────────────────────────────────────────────
ZORAIL_SMTP_ADDR=:1025        # inbound SMTP (use :25 in production)
ZORAIL_HTTP_ADDR=:8090        # web UI + JSON API + MCP (container default :8080)

# ── Auth ──────────────────────────────────────────────────────────────────────
# * When set, the JSON API / UI / ingest require this bearer token. `zorail setup`
#   generates a strong one (zt_…) and the Email Worker authenticates ingest with
#   it. Leave empty only for trusted local-only use.
ZORAIL_API_TOKEN=

# ── Storage & retention ─────────────────────────────────────────────────────────
ZORAIL_DB_PATH=zorail.db
ZORAIL_RETENTION_DAYS=0       # 0 disables sweeping; reserved/forward addrs exempt
ZORAIL_MAX_MESSAGE_BYTES=26214400   # 25 MiB
ZORAIL_MAX_RECIPIENTS=100

# ── Outbound relay (optional; for forwarding) ───────────────────────────────────
ZORAIL_RELAY_HOST=
ZORAIL_RELAY_PORT=587
ZORAIL_RELAY_USER=
ZORAIL_RELAY_PASS=
ZORAIL_RELAY_FROM=
ZORAIL_FORWARD_MAX_TRIES=5

# ── Logging ─────────────────────────────────────────────────────────────────────
ZORAIL_LOG_LEVEL=info         # debug | info | warn | error

# ── Cloudflare automation (managed by `zorail setup` / `zorail up`) ─────────────
# * Scoped Cloudflare API token (reused by setup/doctor/up so you aren't re-prompted).
CLOUDFLARE_API_TOKEN=
# * Run token for the Cloudflare Tunnel, so `zorail up` can start cloudflared.
ZORAIL_TUNNEL_TOKEN=
